generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  ADMIN
  INSTRUTOR
  STUDENT
}

model Instrutor {
  id Int @default(autoincrement()) @id
  name String
  createdAt DateTime
  username String
  password String
  userType UserType @default(INSTRUTOR)
  // colocar anexo
}
